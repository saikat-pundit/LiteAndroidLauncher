<resources>

    <style name="AppBaseTheme" parent="@android:style/Theme.Material.Light.NoActionBar">

        
        
        <item name="android:colorPrimary">@color/gray_500</item>
        
        <item name="android:colorPrimaryDark">@color/gray_700</item>
        


        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowBackground">@color/full_transparent</item>
        <item name="android:windowShowWallpaper">true</item>


    </style>

    <style name="AppSettingsTheme" parent="@android:style/Theme.Material.Light.DarkActionBar">
        <item name="android:colorPrimary">@color/indigo_500</item>

        
        <item name="android:colorPrimaryDark">@color/indigo_700</item>


    </style>

</resources>
